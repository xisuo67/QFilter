{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qfilter",
  "version": "0.1.0",
  "identifier": "com.administrator.qfilter",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:14200",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "qfilter",
        "width": 1200,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRCQzhENzJFMzQ3QUZGODEKUldTQi8zbzBMdGZJUzUvNmY4dGlObUM3YjdydkNOcjNBMG9DYjdac1NORGRPUm14VVl6d3VPOG0K",
      "endpoints": [
        "https://github.com/xisuo67/QFilter/releases/latest/download/latest.json"
      ]
    }
  }
}
